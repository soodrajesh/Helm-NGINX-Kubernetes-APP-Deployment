# Example values.yaml file
# Copy this file to values.yaml and update with your actual values

replicaCount: 2

image:
  repository: nginx
  tag: "latest"
  pullPolicy: IfNotPresent

service:
  type: LoadBalancer
  port: 80

ingress:
  enabled: true
  className: "nginx"
  hosts:
    - host: sample-app.example.com
      paths:
        - path: /
          pathType: Prefix

persistence:
  enabled: true
  accessMode: ReadWriteOnce
  size: 100Mi

configMap:
  APP_ENV: production
  APP_DEBUG: "false"

secret:
  # IMPORTANT: Replace these placeholder values with your actual base64 encoded secrets
  # To encode a password: echo -n "your-actual-password" | base64
  # To encode a username: echo -n "your-actual-username" | base64
  
  # Database credentials
  DB_PASSWORD: <base64-encoded-password>  # Replace with your actual base64 encoded password
  DB_USERNAME: <base64-encoded-username>  # Replace with your actual base64 encoded username
  
  # API keys (if needed)
  API_KEY: <base64-encoded-api-key>       # Replace with your actual base64 encoded API key
  
  # Other secrets
  JWT_SECRET: <base64-encoded-jwt-secret> # Replace with your actual base64 encoded JWT secret

resources:
  requests:
    cpu: 250m
    memory: 64Mi
  limits:
    cpu: 500m
    memory: 128Mi

serviceAccount:
  create: true
  name: ""

autoscaling:
  enabled: false
  minReplicas: 1
  maxReplicas: 100
  targetCPUUtilizationPercentage: 80
  # targetMemoryUtilizationPercentage: 80
